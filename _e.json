{
  "name": "verso-recto",
  "version": "54.1.0",
  "private": true,
  "description": "Verso Recto — jeu de stratégie abstrait. Local (humain/IA) et multijoueur en ligne.",
  "author": {
    "name": "Innocent Twagirumukiza",
    "email": "inno.twa@gmail.com"
  },
  "homepage": "https://github.com/twagirumukiza/verso-recto-v54_1-desktop",
  "main": "electron/main.js",
  "scripts": {
    "test": "node tests/smoke-test.js && node tests/path-planner-test.js && node tests/integration-test.js && node tests/online-forfeit-test.js && node tests/local-persistence-test.js && node tests/online-persistence-test.js && node tests/tournament-test.js && node tests/online-tournament-test.js",
    "start": "electron .",
    "dist": "electron-builder --win --linux",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.twagirumukiza.versorecto",
    "productName": "Verso Recto",
    "copyright": "Copyright © Innocent Twagirumukiza",
    "files": [
      "index.html",
      "online-v39.html",
      "styles.css",
      "online-v39.css",
      "game.js",
      "online-v39.js",
      "assets/**/*",
      "electron/**/*",
      "!tests/**",
      "!.github/**"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Game",
      "maintainer": "Innocent Twagirumukiza <inno.twa@gmail.com>"
    }
  }
}
